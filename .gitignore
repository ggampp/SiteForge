# Dependencies
node_modules/
.pnpm-store/

# Build
dist/
*.tsbuildinfo
.turbo/

# Runtime / local extract store
.siteforge/
*.log

# Env / secrets
.env
.env.*
!.env.example

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Test / coverage
coverage/
playwright-report/
test-results/

# Package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Large media from local extract store only
.siteforge/**/screenshots/**/*.png

# Next builds
**/.next/

# Gallery public clones are generated — keep source under examples/clones
examples/gallery/public/clones/

# Allow reference screenshots inside published example clones
!examples/clones/**/_reference/**/*.png
